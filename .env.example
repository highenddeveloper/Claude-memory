# ============================================================
# AI Dashboard Platform — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- Backend ---
NODE_ENV=production
BACKEND_HOST_PORT=3101
API_KEY=your-secret-api-key-here
LOG_LEVEL=info
CORS_ORIGIN=*

# --- PostgreSQL ---
POSTGRES_USER=ai
POSTGRES_PASSWORD=change-this-password
POSTGRES_DB=ai

# --- Valkey (Redis-compatible) ---
# No password by default for internal network. Set if needed.

# --- SearXNG ---
SEARXNG_SECRET=change-this-searxng-secret

# --- Browserless ---
BROWSERLESS_TOKEN=change-this-browserless-token

# --- Service URL Overrides (optional, for advanced setups) ---
# Keep defaults for Docker Compose internal networking.
# SEARXNG_URL=http://searxng:8080
# BROWSERLESS_URL=http://browserless:3000
# POSTGRES_URL=postgres://ai:change-this-password@postgres:5432/ai
# REDIS_URL=redis://valkey:6379
# QDRANT_URL=http://qdrant:6333
# N8N_URL=http://n8n:5678
# N8N_WEBHOOK_URL=http://n8n:5678/webhook
# EMBEDDING_URL=http://embedding:8000
# MONITOR_URL=http://monitor:8001

# --- n8n ---
N8N_PORT=5678
N8N_USER=admin
N8N_PASSWORD=change-this-n8n-password
N8N_EXTERNAL_URL=http://localhost:5678

# --- Agent ---
AGENT_MAX_CONCURRENCY=3
AGENT_TIMEOUT_MS=300000

# --- Rust Embedding Server ---
# Internal only — no need to change unless custom setup
# EMBEDDING_URL=http://embedding:8000

# --- Go Health Monitor ---
# Internal only
# MONITOR_URL=http://monitor:8001
